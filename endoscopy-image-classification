    "        with torch.no_grad():\n",
    "            for data, target in tqdm(test_loader, desc='Testing'):\n",
    "                data, target = data.to(self.device), target.to(self.device)\n",
    "                \n",
    "                # Get predictions\n",
    "                ensemble_output, individual_outputs = self.model(data, return_individual=True)\n",
    "                \n",
    "                # Store predictions\n",
    "                _, pred = ensemble_output.max(1)\n",
    "                all_preds.extend(pred.cpu().numpy())\n",
    "                all_targets.extend(target.cpu().numpy())\n",
    "                \n",
    "                # Individual model predictions\n",
    "                for model_name, output in individual_outputs.items():\n",
    "                    _, individual_pred = output.max(1)\n",
    "                    individual_preds[model_name].extend(individual_pred.cpu().numpy())\n",
    "        \n",
    "        ensemble_accuracy = 100. * sum([p == t for p, t in zip(all_preds, all_targets)]) / len(all_targets)\n",
    "        print(f\"Ensemble Test Accuracy: {ensemble_accuracy:.2f}%\")\n",
    "        \n",
    "        print(\"\\nIndividual Model Test Accuracies:\")\n",
    "        for model_name, preds in individual_preds.items():\n",
    "            acc = 100. * sum([p == t for p, t in zip(preds, all_targets)]) / len(all_targets)\n",
    "            print(f\"  {model_name}: {acc:.2f}%\")\n",
    "        \n",
    "        print(f\"\\nClassification Report (Ensemble):\")\n",
