    "            \n",
    "            axes[2].set_title('Loss Components', fontsize=12, fontweight='bold')\n",
    "            axes[2].set_xlabel('Epoch')\n",
    "            axes[2].set_ylabel('Loss')\n",
    "            axes[2].legend()\n",
    "            axes[2].grid(True, alpha=0.3)\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "    \n",
    "    def evaluate_student(self, test_loader, class_names):\n",
    "\n",
    "        print(\"\\n🧪 EVALUATING DISTILLED STUDENT MODEL\")\n",
    "        print(\"=\" * 70)\n",
    "        \n",
    "        self.student.eval()\n",
    "        self.teacher.eval()\n",
    "        \n",
    "        all_student_preds = []\n",
    "        all_teacher_preds = []\n",
    "        all_targets = []\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            for data, target in tqdm(test_loader, desc='Testing'):\n",
    "                data, target = data.to(self.device), target.to(self.device)\n",
    "                \n",
    "                with torch.cuda.amp.autocast():\n",
    "                    student_logits = self.student(data)\n",
    "                    _, student_pred = student_logits.max(1)\n",
    "                    try:\n",
    "                        teacher_logits = self.teacher(data)\n",
    "                    except:\n",
    "                        teacher_logits, _ = self.teacher(data, return_features=True)\n",
    "                    _, teacher_pred = teacher_logits.max(1)\n",
    "                \n",
    "                all_student_preds.extend(student_pred.cpu().numpy())\n",
    "                all_teacher_preds.extend(teacher_pred.cpu().numpy())\n",
    "                all_targets.extend(target.cpu().numpy())\n",
    "        student_acc = accuracy_score(all_targets, all_student_preds) * 100\n",
    "        teacher_acc = accuracy_score(all_targets, all_teacher_preds) * 100\n",
    "        \n",
    "        print(f\"\\n📊 Test Results:\")\n",
    "        print(f\"   Student Accuracy: {student_acc:.2f}%\")\n",
    "        print(f\"   Teacher Accuracy: {teacher_acc:.2f}%\")\n",
    "        print(f\"   Accuracy Gap: {teacher_acc - student_acc:.2f}%\")\n",
    "        print(f\"   Knowledge Retention: {(student_acc/teacher_acc)*100:.1f}%\")\n",
    "        \n",
    "        print(f\"\\n📋 Student Classification Report:\")\n",
    "        report = classification_report(\n",
    "            all_targets, \n",
    "            all_student_preds, \n",
    "            target_names=class_names,\n",
    "            digits=3\n",
    "        )\n",
    "        print(report)\n",
    "        \n",
    "        fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "        \n",
    "        student_cm = confusion_matrix(all_targets, all_student_preds)\n",
    "        sns.heatmap(student_cm, annot=True, fmt='d', cmap='Blues',\n",
    "                   xticklabels=class_names, yticklabels=class_names,\n",
    "                   ax=axes[0])\n",
    "        axes[0].set_title(f'Student Model Confusion Matrix\\nAccuracy: {student_acc:.2f}%',\n",
    "                         fontsize=12, fontweight='bold')\n",
    "        axes[0].set_xlabel('Predicted')\n",
    "        axes[0].set_ylabel('Actual')\n",
    "        \n",
    "        # Teacher confusion matrix\n",
    "        teacher_cm = confusion_matrix(all_targets, all_teacher_preds)\n",
    "        sns.heatmap(teacher_cm, annot=True, fmt='d', cmap='Greens',\n",
    "                   xticklabels=class_names, yticklabels=class_names,\n",
    "                   ax=axes[1])\n",
    "        axes[1].set_title(f'Teacher Model Confusion Matrix\\nAccuracy: {teacher_acc:.2f}%',\n",
    "                         fontsize=12, fontweight='bold')\n",
    "        axes[1].set_xlabel('Predicted')\n",
    "        axes[1].set_ylabel('Actual')\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "        \n",
    "        print(f\"\\n📈 Per-Class Performance Comparison:\")\n",
    "        print(f\"{'Class':<20} {'Student Acc':<15} {'Teacher Acc':<15} {'Gap':<10}\")\n",
    "        print(\"-\" * 70)\n",
    "        \n",
    "        for i, class_name in enumerate(class_names):\n",
    "            # Get indices for this class\n",
    "            class_indices = [idx for idx, label in enumerate(all_targets) if label == i]\n",
    "            \n",
    "            if len(class_indices) > 0:\n",
    "                student_class_acc = sum([all_student_preds[idx] == i for idx in class_indices]) / len(class_indices) * 100\n",
    "                teacher_class_acc = sum([all_teacher_preds[idx] == i for idx in class_indices]) / len(class_indices) * 100\n",
    "                gap = teacher_class_acc - student_class_acc\n",
    "                \n",
    "                print(f\"{class_name:<20} {student_class_acc:>6.2f}%        {teacher_class_acc:>6.2f}%        {gap:>6.2f}%\")\n",
    "        \n",
    "        return student_acc, report\n",
    "\n",
    "    def save_distilled_model(self, filepath='/kaggle/working/distilled_student.pth'):\n",
