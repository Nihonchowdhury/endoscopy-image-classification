    "class DatasetAnalyzer:\n",
    "    def __init__(self, dataset_path):\n",
    "        self.classes = sorted([d for d in os.listdir(dataset_path)\n",
    "                      if os.path.isdir(os.path.join(dataset_path, d))])\n",
    "        self.datase_path = dataset_path\n",
    "        self.class_to_idx = {class_name: idx for idx, class_name in enumerate(self.classes)}\n",
    "\n",
    "    def analyze_dataset_structure(self):\n",
    "        print(\"Dataset Path: \", dataset_path)\n",
    "        print(\"Number of classes: \", len(self.classes))\n",
    "        print(\"Classes are: \", self.classes)\n",
    "        class_count = {}\n",
    "        total_images = 0\n",
    "\n",
    "        for class_name in self.classes:\n",
    "            class_dir = os.path.join(self.datase_path, class_name)\n",
    "            image_files = [filename for filename in os.listdir(class_dir)\n",
    "                if filename.lower().endswith(('.png', '.jpg', '.jpeg', '.bmp', '.tiff'))]\n",
    "            class_count[class_name] = len(image_files)\n",
    "            total_images += len(image_files)\n",
    "        print(\"Total Images: \", total_images)\n",
    "        for class_name, count in class_count.items():\n",
    "            percentage = (count/total_images)*100\n",
    "            print(f\"  {class_name}: {count} images ({percentage:.2f}%)\")\n",
    "        \n",
    "        return class_count, total_images\n",
    "\n",
    "    def analyze_image_properties(self, sample_size=100):\n",
    "        dimensions = []\n",
    "        file_sizes = []\n",
    "        sample_count = 0\n",
    "        for class_name in self.classes:\n",
    "            class_dir = os.path.join(self.datase_path, class_name)\n",
    "            image_files = [filename for filename in os.listdir(class_dir)\n",
    "                            if filename.lower().endswith(('.png', '.jpg', '.jpeg', '.bmp', '.tiff'))]\n",
    "\n",
    "            for filename in image_files[:sample_size//len(self.classes)]:\n",
    "                if sample_count>=sample_size:\n",
    "                    break\n",
    "                image_path = os.path.join(class_dir, filename)\n",
    "                with Image.open(image_path) as img:\n",
    "                    dimensions.append(img.size)\n",
    "                    file_sizes.append(os.path.getsize(image_path))\n",
    "                sample_count += 1\n",
    "        widths = [d[0] for d in dimensions]\n",
    "        heights = [d[1] for d in dimensions]\n",
    "\n",
    "        print(f\"Analyzed {len(dimensions)} images\")\n",
    "        print(f\"Width - Min: {min(widths)} Max: {max(widths)} Average {np.mean(widths)}\")\n",
    "        print(f\"Heights - Min: {min(heights)} Max: {max(heights)} Average {np.mean(heights)}\")\n",
    "        print(f\"File size - Min: {min(file_sizes)/1024}KB Max: {max(file_sizes)/1024}KB\")\n",
    "\n",
    "        return dimensions, file_sizes\n",
    "\n",
    "    def visualize_class_distribution(self, class_counts):\n",
    "        plt.figure(figsize=(12, 6))\n",
    "        plt.subplot(1,2,1)\n",
    "        plt.bar(class_counts.keys(), class_counts.values())\n",
    "        plt.title(\"Image per class\")\n",
    "        plt.xlabel(\"Class\")\n",
    "        plt.ylabel(\"Number of images\")\n",
    "        plt.xticks(rotation=45)\n",
    "\n",
    "        plt.subplot(1,2,2)\n",
    "        plt.pie(class_counts.values(), labels=class_counts.keys(), autopct=\"%1.1f%%\")\n",
    "        plt.title(\"Class distribution\")\n",
    "\n",
    "        plt.tight_layout()\n",
    "        plt.show()\n",
    "        plt.savefig(\"class_distribution.png\")\n",
    "\n",
    "    def check_class_balance(self, class_counts):\n",
    "        counts = list(class_counts.values())\n",
    "        max_count = max(counts)\n",
    "        min_count = min(counts)\n",
    "        imbalance_ratio = max_count/min_count\n",
    "        if imbalance_ratio > 2:\n",
    "            print(\"Significant imbalance in the dataset\")\n",
    "        else:\n",
    "            print(\"Dataset is relatively balanced\")"
