    "def train_student_baseline(student_model, train_loader, val_loader, test_loader,\n",
    "                          num_classes, device='cuda', num_epochs=30):               #Change Epoch Here\n",
    "\n",
    "    from torch.optim import AdamW\n",
    "    from torch.optim.lr_scheduler import CosineAnnealingLR\n",
    "    \n",
    "    student_model = student_model.to(device)\n",
    "    optimizer = AdamW(student_model.parameters(), lr=1e-3, weight_decay=1e-4)\n",
    "    scheduler = CosineAnnealingLR(optimizer, T_max=len(train_loader) * num_epochs)\n",
    "    criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "    \n",
    "    best_val_acc = 0.0\n",
    "    patience_counter = 0\n",
    "    patience = 8\n",
    "    \n",
    "    for epoch in range(num_epochs):\n",
    "        # Train\n",
    "        student_model.train()\n",
    "        for data, target in train_loader:\n",
    "            data, target = data.to(device), target.to(device)\n",
    "            optimizer.zero_grad()\n",
    "            output = student_model(data)\n",
    "            loss = criterion(output, target)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            scheduler.step()\n",
    "        \n",
    "        # Validate\n",
    "        student_model.eval()\n",
    "        correct = 0\n",
    "        total = 0\n",
    "        with torch.no_grad():\n",
    "            for data, target in val_loader:\n",
    "                data, target = data.to(device), target.to(device)\n",
    "                output = student_model(data)\n",
    "                _, pred = output.max(1)\n",
    "                total += target.size(0)\n",
    "                correct += pred.eq(target).sum().item()\n",
    "        \n",
    "        val_acc = 100. * correct / total\n",
    "        \n",
    "        if val_acc > best_val_acc:\n",
    "            best_val_acc = val_acc\n",
    "            patience_counter = 0\n",
    "        else:\n",
    "            patience_counter += 1\n",
    "            if patience_counter >= patience:\n",
    "                break\n",
    "    \n",
    "    # Test\n",
    "    test_acc = evaluate_model(student_model, test_loader, device)\n",
    "    \n",
    "    return test_acc, best_val_acc\n",
    "\n",
    "def evaluate_model(model, test_loader, device='cuda'):\n",
    "    \"\"\"Evaluate model on test set\"\"\"\n",
    "    model.eval()\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for data, target in test_loader:\n",
    "            data, target = data.to(device), target.to(device)\n",
    "            \n",
    "            try:\n",
    "                output = model(data)\n",
    "            except:\n",
    "                output, _ = model(data, return_features=True)\n",
    "            \n",
    "            _, pred = output.max(1)\n",
    "            total += target.size(0)\n",
    "            correct += pred.eq(target).sum().item()\n",
    "    \n",
    "    return 100. * correct / total"
   ]
