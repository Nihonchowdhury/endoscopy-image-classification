    "class ExperimentManager:\n",
    "    \n",
    "    def __init__(self, experiment_name, save_dir='experiments'):\n",
    "        self.experiment_name = experiment_name\n",
    "        self.save_dir = save_dir\n",
    "        self.timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "        \n",
    "        # Create directory structure\n",
    "        self.exp_dir = os.path.join(save_dir, f\"{experiment_name}_{self.timestamp}\")\n",
    "        os.makedirs(self.exp_dir, exist_ok=True)\n",
    "        os.makedirs(os.path.join(self.exp_dir, 'models'), exist_ok=True)\n",
    "        os.makedirs(os.path.join(self.exp_dir, 'figures'), exist_ok=True)\n",
    "        os.makedirs(os.path.join(self.exp_dir, 'tables'), exist_ok=True)\n",
    "        os.makedirs(os.path.join(self.exp_dir, 'logs'), exist_ok=True)\n",
    "        \n",
    "        # Storage for all experiment results\n",
    "        self.results = []\n",
    "        self.best_configs = {}\n",
    "        \n",
    "        print(f\"📁 Experiment directory created: {self.exp_dir}\")\n",
    "        \n",
    "    def log_experiment(self, config, results, model_path=None):\n",
    "        experiment_record = {\n",
    "            'timestamp': datetime.now().isoformat(),\n",
    "            'config': config,\n",
    "            'results': results,\n",
    "            'model_path': model_path\n",
    "        }\n",
    "        \n",
    "        self.results.append(experiment_record)\n",
    "        \n",
    "        # Save to JSON\n",
    "        results_file = os.path.join(self.exp_dir, 'logs', 'all_results.json')\n",
    "        with open(results_file, 'w') as f:\n",
    "            json.dump(self.results, f, indent=2)\n",
    "        \n",
    "        print(f\"✅ Logged experiment: {config.get('name', 'unnamed')}\")\n",
    "\n",
    "    def get_results_dataframe(self):\n",
    "        data = []\n",
    "        \n",
    "        for exp in self.results:\n",
    "            row = {}\n",
    "            for key, val in exp['config'].items():\n",
    "                row[f'config_{key}'] = val\n",
    "                \n",
    "            for key, val in exp['results'].items():\n",
    "                row[f'result_{key}'] = val\n",
    "            \n",
    "            data.append(row)\n",
    "        \n",
    "        return pd.DataFrame(data)\n",
    "    \n",
    "    def generate_comparison_table(self, metrics=['test_acc', 'val_acc', 'params', 'inference_time']):\n",
    "\n",
    "        df = self.get_results_dataframe()\n",
    "        \n",
    "        # Create LaTeX table\n",
    "        latex_str = \"\\\\begin{table}[h]\\n\"\n",
    "        latex_str += \"\\\\centering\\n\"\n",
    "        latex_str += \"\\\\caption{Comparison of Different Experimental Configurations}\\n\"\n",
    "        latex_str += \"\\\\label{tab:comparison}\\n\"\n",
    "        latex_str += \"\\\\begin{tabular}{l\" + \"c\" * len(metrics) + \"}\\n\"\n",
    "        latex_str += \"\\\\hline\\n\"\n",
    "        \n",
    "        # Header\n",
    "        header = \"Method & \" + \" & \".join([m.replace('_', ' ').title() for m in metrics]) + \" \\\\\\\\\\n\"\n",
    "        latex_str += header\n",
    "        latex_str += \"\\\\hline\\n\"\n",
    "        \n",
    "        # Rows\n",
    "        for idx, row in df.iterrows():\n",
    "            method_name = row.get('config_name', f'Exp_{idx+1}')\n",
    "            values = [f\"{row.get(f'result_{m}', 'N/A'):.2f}\" if isinstance(row.get(f'result_{m}'), (int, float)) else str(row.get(f'result_{m}', 'N/A')) for m in metrics]\n",
    "            latex_str += f\"{method_name} & \" + \" & \".join(values) + \" \\\\\\\\\\n\"\n",
    "        \n",
    "        latex_str += \"\\\\hline\\n\"\n",
    "        latex_str += \"\\\\end{tabular}\\n\"\n",
    "        latex_str += \"\\\\end{table}\\n\"\n",
    "        \n",
    "        # Save to file\n",
    "        table_file = os.path.join(self.exp_dir, 'tables', 'comparison_table.tex')\n",
    "        with open(table_file, 'w') as f:\n",
    "            f.write(latex_str)\n",
    "        \n",
    "        print(f\"📊 LaTeX table saved: {table_file}\")\n",
    "        return latex_str\n",
    "\n",
    "    def plot_comparison(self, metric='test_acc', figsize=(12, 8)):\n",
    "\n",
    "        df = self.get_results_dataframe()\n",
    "        \n",
    "        plt.figure(figsize=figsize)\n",
    "        \n",
    "        # Get experiment names and values\n",
    "        names = [row.get('config_name', f'Exp_{i+1}') for i, row in df.iterrows()]\n",
    "        values = [row.get(f'result_{metric}', 0) for _, row in df.iterrows()]\n",
    "        \n",
    "        # Create bar plot\n",
    "        bars = plt.bar(range(len(names)), values, color='steelblue', alpha=0.8, edgecolor='black')\n",
    "        \n",
    "        # Highlight best result\n",
    "        best_idx = np.argmax(values)\n",
    "        bars[best_idx].set_color('darkgreen')\n",
    "        bars[best_idx].set_alpha(1.0)\n",
    "        \n",
    "        # Customize plot\n",
    "        plt.xlabel('Configuration', fontsize=12, fontweight='bold')\n",
    "        plt.ylabel(metric.replace('_', ' ').title(), fontsize=12, fontweight='bold')\n",
    "        plt.title(f'Comparison of {metric.replace(\"_\", \" \").title()} Across Configurations', \n",
    "                 fontsize=14, fontweight='bold')\n",
    "        plt.xticks(range(len(names)), names, rotation=45, ha='right')\n",
    "        plt.grid(axis='y', alpha=0.3)\n",
    "        plt.tight_layout()\n",
    "        \n",
    "        # Save figure\n",
    "        fig_path = os.path.join(self.exp_dir, 'figures', f'comparison_{metric}.png')\n",
    "        plt.savefig(fig_path, dpi=300, bbox_inches='tight')\n",
    "        plt.show()\n",
    "        \n",
    "        print(f\"📈 Comparison plot saved: {fig_path}\")"
   ]
