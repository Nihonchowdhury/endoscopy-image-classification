    "class KnowledgeDistillationTrainer:\n",
    "    \n",
    "    def __init__(self, teacher_model, student_model, train_loader, val_loader, \n",
    "                 num_classes, device='cuda'):\n",
    "        \n",
    "        self.teacher = teacher_model.to(device)\n",
    "        self.student = student_model.to(device)\n",
    "        self.train_loader = train_loader\n",
    "        self.val_loader = val_loader\n",
    "        self.num_classes = num_classes\n",
    "        self.device = device\n",
    "        \n",
    "        self.teacher.eval()\n",
    "        for param in self.teacher.parameters():\n",
    "            param.requires_grad = False\n",
    "        \n",
    "        self.history = defaultdict(list)\n",
    "        \n",
    "        self.scaler = torch.cuda.amp.GradScaler()\n",
    "        \n",
    "        print(\"✅ Knowledge Distillation Trainer initialized\")\n",
    "        print(f\"   Teacher parameters: {sum(p.numel() for p in self.teacher.parameters()):,}\")\n",
    "        print(f\"   Student parameters: {sum(p.numel() for p in self.student.parameters()):,}\")\n",
    "    \n",
    "    def setup_training(self, \n",
    "                      temperature=4.0,\n",
    "                      alpha=0.7,\n",
    "                      beta=0.3,\n",
    "                      use_feature_distillation=True,\n",
    "                      use_attention_transfer=True,\n",
    "                      feature_weight=0.5,\n",
    "                      attention_weight=0.3,\n",
    "                      learning_rate=1e-3,\n",
    "                      weight_decay=1e-4,\n",
    "                      label_smoothing=0.0,\n",
    "                      use_progressive=False):\n",
    "        \n",
    "        print(\"\\n⚙️  SETTING UP KNOWLEDGE DISTILLATION\")\n",
    "        \n",
    "        self.distillation_loss = DistillationLoss(\n",
    "            temperature=temperature,\n",
    "            alpha=alpha,\n",
    "            beta=beta\n",
    "        )\n",
    "        \n",
    "        print(f\"📚 Main Distillation Loss:\")\n",
    "        print(f\"   Temperature: {temperature}\")\n",
    "        print(f\"   Alpha (soft targets): {alpha}\")\n",
    "        print(f\"   Beta (hard targets): {beta}\")\n",
    "        \n",
    "        self.use_feature_distillation = use_feature_distillation\n",
    "        if use_feature_distillation:\n",
    "            self.feature_loss = FeatureDistillationLoss(feature_weight=feature_weight)\n",
    "            print(f\"\\n🎯 Feature Distillation: ENABLED\")\n",
    "            print(f\"   Feature weight: {feature_weight}\")\n",
    "\n",
    "        self.use_attention_transfer = use_attention_transfer\n",
    "        if use_attention_transfer:\n",
    "            self.attention_loss = AttentionTransferLoss(attention_weight=attention_weight)\n",
    "            print(f\"\\n👁️  Attention Transfer: ENABLED\")\n",
    "            print(f\"   Attention weight: {attention_weight}\")\n",
    "        \n",
    "        self.optimizer = optim.AdamW(\n",
    "            self.student.parameters(),\n",
    "            lr=learning_rate,\n",
    "            weight_decay=weight_decay,\n",
    "            betas=(0.9, 0.999)\n",
    "        )\n",
    "        \n",
    "        self.scheduler = CosineAnnealingLR(\n",
    "            self.optimizer,\n",
    "            T_max=len(self.train_loader) * 50,  # Assuming 50 epochs max\n",
    "            eta_min=learning_rate * 0.01\n",
    "        )\n",
    "        \n",
    "        print(f\"\\n🔧 Optimizer: AdamW\")\n",
    "        print(f\"   Learning rate: {learning_rate}\")\n",
    "        print(f\"   Weight decay: {weight_decay}\")\n",
    "        print(f\"   Scheduler: CosineAnnealingLR\")\n",
    "        \n",
    "        print(\"=\" * 70)\n",
    "    \n",
    "    def train_epoch(self, epoch):\n",
    "\n",
    "        self.student.train()\n",
    "        self.teacher.eval() \n",
    "\n",
    "        running_loss = 0.0\n",
    "        running_distill_loss = 0.0\n",
    "        running_student_loss = 0.0\n",
    "        running_feature_loss = 0.0\n",
    "        running_attention_loss = 0.0\n",
    "        correct = 0\n",
    "        total = 0\n",
    "        \n",
    "        pbar = tqdm(self.train_loader, desc=f'Epoch {epoch+1} [Train]')\n",
    "        \n",
    "        for batch_idx, (data, target) in enumerate(pbar):\n",
    "            data, target = data.to(self.device), target.to(self.device)\n",
    "\n",
    "            with torch.cuda.amp.autocast():\n",
    "                with torch.no_grad():\n",
    "                    try:\n",
    "                        teacher_logits, teacher_features = self.teacher(data, return_features=True)\n",
    "                    except:\n",
    "                        teacher_logits = self.teacher(data)\n",
    "                        teacher_features = None\n",
    "                \n",
    "                try:\n",
    "                    student_logits, student_features = self.student(data, return_features=True)\n",
    "                except:\n",
    "                    student_logits = self.student(data)\n",
    "                    student_features = None\n",
    "\n",
    "                distill_loss, loss_dict = self.distillation_loss(\n",
    "                    student_logits, \n",
    "                    teacher_logits, \n",
    "                    target\n",
    "                )\n",
    "                \n",
    "                total_loss = distill_loss\n",
    "                \n",
    "                if self.use_feature_distillation and student_features and teacher_features:\n",
    "                    feat_loss = self.feature_loss(student_features, teacher_features)\n",
    "                    total_loss += feat_loss\n",
    "                    running_feature_loss += feat_loss.item()\n",
    "\n",
    "                if self.use_attention_transfer and student_features and teacher_features:\n",
    "                    attn_loss = self.attention_loss(student_features, teacher_features)\n",
    "                    total_loss += attn_loss\n",
    "                    running_attention_loss += attn_loss.item()\n",
    "            \n",
    "            self.optimizer.zero_grad()\n",
    "            self.scaler.scale(total_loss).backward()\n",
    "            self.scaler.unscale_(self.optimizer)\n",
    "            torch.nn.utils.clip_grad_norm_(self.student.parameters(), max_norm=1.0)\n",
    "            self.scaler.step(self.optimizer)\n",
    "            self.scaler.update()\n",
    "            self.scheduler.step()\n",
    "\n",
    "            running_loss += total_loss.item()\n",
    "            running_distill_loss += loss_dict['distillation']\n",
    "            running_student_loss += loss_dict['student']\n",
    "            \n",
    "            _, predicted = student_logits.max(1)\n",
    "            total += target.size(0)\n",
    "            correct += predicted.eq(target).sum().item()\n",
    "            \n",
    "            pbar.set_postfix({\n",
    "                'Loss': f'{total_loss.item():.4f}',\n",
    "                'Acc': f'{100.*correct/total:.2f}%',\n",
    "                'LR': f'{self.scheduler.get_last_lr()[0]:.6f}'\n",
    "            })\n",
    "\n",
    "            if batch_idx % 50 == 0:\n",
    "                torch.cuda.empty_cache()\n",
    "        \n",
    "        num_batches = len(self.train_loader)\n",
    "        epoch_loss = running_loss / num_batches\n",
    "        epoch_acc = 100. * correct / total\n",
    "\n",
    "        self.history['train_loss'].append(epoch_loss)\n",
    "        self.history['train_acc'].append(epoch_acc)\n",
    "        self.history['train_distill_loss'].append(running_distill_loss / num_batches)\n",
    "        self.history['train_student_loss'].append(running_student_loss / num_batches)\n",
    "        \n",
    "        if self.use_feature_distillation:\n",
    "            self.history['train_feature_loss'].append(running_feature_loss / num_batches)\n",
    "        if self.use_attention_transfer:\n",
    "            self.history['train_attention_loss'].append(running_attention_loss / num_batches)\n",
    "        \n",
    "        return epoch_loss, epoch_acc\n",
    "    \n",
    "    def validate_epoch(self, epoch):\n",
    "\n",
    "        self.student.eval()\n",
