    "class AttentionTransferLoss(nn.Module):\n",
    "\n",
    "    def __init__(self, attention_weight=1.0):\n",
    "\n",
    "        super(AttentionTransferLoss, self).__init__()\n",
    "        self.attention_weight = attention_weight\n",
    "        \n",
    "    def compute_attention_map(self, features):\n",
    "\n",
    "        attention = torch.sum(torch.abs(features), dim=1, keepdim=True)\n",
    "        \n",
    "        batch_size = attention.size(0)\n",
    "        attention = attention.view(batch_size, -1)\n",
    "        attention = attention / (torch.sum(attention, dim=1, keepdim=True) + 1e-8)\n",
    "        attention = attention.view(batch_size, 1, features.size(2), features.size(3))\n",
    "        \n",
    "        return attention\n",
    "    \n",
    "    def forward(self, student_features, teacher_features):\n",
    "\n",
    "        attention_loss = 0.0\n",
    "        num_matched = 0\n",
    "        \n",
    "        for key in student_features.keys():\n",
    "            if key in teacher_features:\n",
    "                s_feat = student_features[key]\n",
    "                t_feat = teacher_features[key]\n",
    "                \n",
    "                if len(s_feat.shape) == 4:\n",
    "                    s_attention = self.compute_attention_map(s_feat)\n",
    "                    t_attention = self.compute_attention_map(t_feat)\n",
    "                    \n",
    "                    if s_attention.shape != t_attention.shape:\n",
    "                        s_attention = F.interpolate(\n",
    "                            s_attention, \n",
    "                            size=t_attention.shape[2:], \n",
    "                            mode='bilinear', \n",
    "                            align_corners=False\n",
    "                        )\n",
    "                    \n",
    "                    attention_loss += F.mse_loss(s_attention, t_attention)\n",
    "                    num_matched += 1\n",
    "        \n",
    "        if num_matched > 0:\n",
    "            attention_loss = attention_loss / num_matched\n",
    "        \n",
    "        return self.attention_weight * attention_loss"
   ]
