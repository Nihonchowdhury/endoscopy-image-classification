    "class FeatureDistillationLoss(nn.Module):\n",
    "    \n",
    "    def __init__(self, feature_weight=1.0):\n",
    "\n",
    "        super(FeatureDistillationLoss, self).__init__()\n",
    "        self.feature_weight = feature_weight\n",
    "        \n",
    "    def forward(self, student_features, teacher_features):\n",
    "\n",
    "        feature_loss = 0.0\n",
    "        num_matched = 0\n",
    "        \n",
    "        for key in student_features.keys():\n",
    "            if key in teacher_features:\n",
    "                s_feat = student_features[key]\n",
    "                t_feat = teacher_features[key]\n",
    "                \n",
    "                if s_feat.shape != t_feat.shape:\n",
    "                    if len(s_feat.shape) == 4:\n",
    "                        s_feat = F.adaptive_avg_pool2d(s_feat, t_feat.shape[2:])\n",
    "                    \n",
    "                    if s_feat.shape[1] != t_feat.shape[1]:\n",
    "                        continue\n",
    "                \n",
    "                feature_loss += F.mse_loss(s_feat, t_feat)\n",
    "                num_matched += 1\n",
    "\n",
    "        if num_matched > 0:\n",
    "            feature_loss = feature_loss / num_matched\n",
    "        \n",
    "        return self.feature_weight * feature_loss"
   ]
