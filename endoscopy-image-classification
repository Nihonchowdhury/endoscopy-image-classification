    "class ProgressiveDistillationTrainer(KnowledgeDistillationTrainer):\n",
    "    \n",
    "    def __init__(self, teacher_model, student_model, train_loader, val_loader,\n",
    "                 num_classes, device='cuda'):\n",
    "        super().__init__(teacher_model, student_model, train_loader, val_loader,\n",
    "                        num_classes, device)\n",
    "        self.initial_temperature = None\n",
    "        self.final_temperature = None\n",
    "        self.initial_alpha = None\n",
    "        self.final_alpha = None\n",
    "        \n",
    "    def setup_progressive_training(self,\n",
    "                                   initial_temperature=6.0,\n",
    "                                   final_temperature=2.0,\n",
    "                                   initial_alpha=0.9,\n",
    "                                   final_alpha=0.5,\n",
    "                                   **kwargs):\n",
    "\n",
    "        self.initial_temperature = initial_temperature\n",
    "        self.final_temperature = final_temperature\n",
    "        self.initial_alpha = initial_alpha\n",
    "        self.final_alpha = final_alpha\n",
    "        \n",
    "        # Setup with initial values\n",
    "        self.setup_training(\n",
    "            temperature=initial_temperature,\n",
    "            alpha=initial_alpha,\n",
    "            beta=1.0 - initial_alpha,\n",
    "            **kwargs\n",
    "        )\n",
    "        \n",
    "        print(f\"\\n🔄 PROGRESSIVE DISTILLATION ENABLED\")\n",
    "        print(f\"   Temperature: {initial_temperature} → {final_temperature}\")\n",
    "        print(f\"   Alpha (soft targets): {initial_alpha} → {final_alpha}\")\n",
    "    \n",
    "    def update_distillation_params(self, current_epoch, total_epochs):\n",
    "        \n",
    "        progress = current_epoch / total_epochs\n",
    "        \n",
    "        new_temperature = self.initial_temperature + \\\n",
    "                         (self.final_temperature - self.initial_temperature) * progress\n",
    "        self.distillation_loss.temperature = new_temperature\n",
    "        \n",
    "        new_alpha = self.initial_alpha + \\\n",
    "                   (self.final_alpha - self.initial_alpha) * progress\n",
    "        new_beta = 1.0 - new_alpha\n",
    "        \n",
    "        self.distillation_loss.alpha = new_alpha\n",
    "        self.distillation_loss.beta = new_beta\n",
    "        \n",
    "        if current_epoch % 5 == 0:  # Print every 5 epochs\n",
    "            print(f\"\\n🔄 Updated distillation parameters:\")\n",
    "            print(f\"   Temperature: {new_temperature:.2f}\")\n",
    "            print(f\"   Alpha: {new_alpha:.2f}, Beta: {new_beta:.2f}\")\n",
    "    \n",
    "    def train(self, num_epochs=30, patience=10, min_delta=0.001):                #Change Epoch Here\n",
    "\n",
    "        original_train_epoch = self.train_epoch\n",
    "\n",
    "        def progressive_train_epoch(epoch):\n",
    "            self.update_distillation_params(epoch, num_epochs)\n",
    "            return original_train_epoch(epoch)\n",
    "        \n",
    "        self.train_epoch = progressive_train_epoch\n",
    "        result = super().train(num_epochs, patience, min_delta)\n",
    "        self.train_epoch = original_train_epoch\n",
    "        \n",
    "        return result"
