    "        self.initial_conv = ConvBlock(input_channels, base_channels, kernel_size=7, stride=2, padding=3)\n",
    "        self.maxpool = nn.MaxPool2d(kernel_size=3, stride=2, padding=1)\n",
    "        \n",
    "        self.stage1 = self._make_stage(base_channels, base_channels * 2, num_blocks=2, stride=1)\n",
    "        \n",
    "        self.stage2 = self._make_stage(base_channels * 2, base_channels * 4, num_blocks=2, stride=2)\n",
    "        \n",
    "        self.stage3 = self._make_stage(base_channels * 4, base_channels * 8, num_blocks=3, stride=2, \n",
    "                                       use_attention=use_attention)\n",
    "        \n",
    "        self.stage4 = self._make_stage(base_channels * 8, base_channels * 16, num_blocks=2, stride=2, \n",
    "                                       use_attention=use_attention)\n",
    "        \n",
    "        self.avgpool = nn.AdaptiveAvgPool2d((1, 1))\n",
    "        \n",
    "        self.dropout = nn.Dropout(dropout_rate)\n",
    "        self.fc = nn.Linear(base_channels * 16, num_classes)\n",
    "\n",
    "        self._initialize_weights()\n",
    "    \n",
    "    def _make_stage(self, in_channels, out_channels, num_blocks, stride, use_attention=False):\n",
    "        \n",
    "        layers = []\n",
    "        layers.append(ResidualBlock(in_channels, out_channels, stride, use_attention, self.attention_type))\n",
    "        for _ in range(1, num_blocks):\n",
    "            layers.append(ResidualBlock(out_channels, out_channels, 1, use_attention, self.attention_type))\n",
    "        \n",
    "        return nn.Sequential(*layers)\n",
    "    \n",
    "    def _initialize_weights(self):\n",
    "        for m in self.modules():\n",
    "            if isinstance(m, nn.Conv2d):\n",
    "                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')\n",
    "            elif isinstance(m, nn.BatchNorm2d):\n",
