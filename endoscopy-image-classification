    "def create_medical_transform():\n",
    "    basic_transforms = transforms.Compose([\n",
    "        transforms.Resize((224, 224)),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize(mean=[0.485, 0.456, 0.406],\n",
    "                            std=[0.229, 0.224, 0.225])  #Normalize with ImageNet mean and std \n",
    "    ])\n",
    "\n",
    "    train_transforms = transforms.Compose([\n",
    "        transforms.Resize((256, 256)),\n",
    "        transforms.RandomResizedCrop(224, scale=(0.8, 1.0)),\n",
    "        transforms.RandomHorizontalFlip(p=0.5),\n",
    "        transforms.RandomVerticalFlip(p=0.3),\n",
    "        transforms.RandomRotation(degrees=15),\n",
    "        transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.1, hue=0.005),\n",
    "        transforms.RandomGrayscale(p=0.1),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize(mean=[0.485, 0.456, 0.406],\n",
    "                            std=[0.229, 0.224, 0.225]),   #Normalize with ImageNet mean and std\n",
    "        transforms.RandomErasing(p=0.1, scale=(0.02, 0.1))\n",
    "    ])\n",
    "\n",
    "    val_transforms = transforms.Compose([\n",
    "        transforms.Resize((224, 224)),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize(mean=[0.485, 0.456, 0.406],\n",
    "                            std=[0.229, 0.224, 0.225])   #Normalize with ImageNet mean and std\n",
    "    ])\n",
    "\n",
    "    return basic_transforms, train_transforms, val_transforms\n",
    "\n",
    "def create_data_split(dataset_path, test_size=0.2, val_size=0.1, random_state=42):\n",
    "    basic_transforms, _, _ = create_medical_transform()\n",
    "    full_dataset = EndoscopyDataset(dataset_path, basic_transforms)\n",
    "    labels = [sample[1] for sample in full_dataset.samples]\n",
    "    train_idx, test_idx = train_test_split(range(len(full_dataset)), test_size = test_size, stratify=labels, random_state = random_state)\n",
    "    train_val_labels = [labels[i] for i in train_idx]\n",
    "    train_idx, val_idx = train_test_split(train_idx, test_size = val_size/(1-test_size), stratify=train_val_labels, random_state = random_state)\n",
    "\n",
    "    print(f\"Total samples: {len(full_dataset)}\")\n",
    "    print(f\"Train samples: {len(train_idx)} ({len(train_idx)/len(full_dataset)*100:.1f}%)\")\n",
    "    print(f\"Validation samples: {len(val_idx)} ({len(val_idx)/len(full_dataset)*100:.1f}%)\")\n",
    "    print(f\"Test samples: {len(test_idx)} ({len(test_idx)/len(full_dataset)*100:.1f}%)\")\n",
    "    \n",
    "    return train_idx, val_idx, test_idx, full_dataset.class_to_idx\n",
    "\n",
    "def create_data_loader(dataset_path, train_indices, val_indices, test_indices, class_to_idx, batch_size=16, num_workers=2):\n",
    "    _, train_transform, val_transform = create_medical_transform()\n",
    "    \n",
    "    train_dataset = EndoscopyDataset(dataset_path, transform = train_transform, class_to_idx = class_to_idx)\n",
    "    val_dataset = EndoscopyDataset(dataset_path, transform = val_transform, class_to_idx = class_to_idx)\n",
    "    test_dataset = EndoscopyDataset(dataset_path, transform = val_transform, class_to_idx = class_to_idx)\n",
    "\n",
    "    train_subset = torch.utils.data.Subset(train_dataset, train_indices)\n",
    "    val_subset = torch.utils.data.Subset(val_dataset, val_indices)\n",
    "    test_subset = torch.utils.data.Subset(test_dataset, test_indices)\n",
    "\n",
    "    train_loader = DataLoader(train_subset, batch_size=batch_size, shuffle=True, num_workers = num_workers, pin_memory = torch.cuda.is_available())\n",
    "    val_loader = DataLoader(val_subset, batch_size=batch_size, shuffle=True, num_workers = num_workers, pin_memory = torch.cuda.is_available())\n",
    "    test_loader = DataLoader(test_subset, batch_size=batch_size, shuffle=True, num_workers = num_workers, pin_memory = torch.cuda.is_available())\n",
    "\n",
    "    print(f\"Train batches: {len(train_loader)}\")\n",
    "    print(f\"Validation batches: {len(val_loader)}\")\n",
    "    print(f\"Test batches: {len(test_loader)}\")\n",
    "    print(f\"Batch size: {batch_size}\")\n",
    "\n",
    "    return train_loader, val_loader, test_loader\n",
    "    \n",
    "def visualize_sample_images(data_loader, class_names, num_samples=8):\n",
    "    data_iter = iter(data_loader)\n",
    "    images, labels = next(data_iter)\n",
    "\n",
    "    mean = torch.tensor([0.485, 0.456, 0.406])\n",
    "    std = torch.tensor([0.229, 0.224, 0.225])\n",
    "\n",
    "    def denormalize(tensor):\n",
    "        for t, m, s in zip(tensor, mean, std):\n",
    "            t.mul_(s).add_(m)\n",
    "        return torch.clamp(tensor, 0, 1)\n",
    "    fig, axes = plt.subplots(2, 4, figsize=(15, 8))\n",
    "    axes = axes.ravel()\n",
    "    for i in range(min(num_samples, len(images))):\n",
    "        img = denormalize(images[i].clone())\n",
    "        img_np = img.permute(1, 2, 0).numpy()\n",
    "        axes[i].imshow(img_np)\n",
    "        axes[i].set_title(f\"Class; {class_names[labels[i].item()]}\")\n",
    "        axes[i].axis(\"off\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"sample_visualization.png\")\n",
    "    plt.show()\n",
    "\n",
    "def analyze_endoscopy_dataset(dataset_path):\n",
    "    analyzer = DatasetAnalyzer(dataset_path)\n",
    "    class_counts, total_images = analyzer.analyze_dataset_structure()\n",
    "    dimensions, file_size = analyzer.analyze_image_properties()\n",
    "    analyzer.check_class_balance(class_counts)\n",
    "    analyzer.visualize_class_distribution(class_counts)\n",
    "\n",
    "    train_indices, val_indices, test_indices, class_to_idx = create_data_split(dataset_path)\n",
    "    train_loader, val_loader, test_loader = create_data_loader(dataset_path, train_indices, val_indices, test_indices, class_to_idx)\n",
    "    class_names = list(class_to_idx.keys())\n",
    "    visualize_sample_images(train_loader, class_names)\n",
    "\n",
    "    return {\n",
    "        'train_loader': train_loader,\n",
    "        'val_loader': val_loader,\n",
    "        'test_loader': test_loader,\n",
    "        'class_to_idx': class_to_idx,\n",
    "        'class_names': class_names,\n",
    "        'dataset_stats': {\n",
    "            'total_images': total_images,\n",
    "            'class_counts': class_counts,\n",
    "            'num_classes': len(class_names)\n",
    "        }\n",
    "    }"
