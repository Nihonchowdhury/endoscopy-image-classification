    "    def evaluate_on_test(self, test_loader, class_names):\n",
    "\n",
    "        print(\"\\nEVALUATING ENSEMBLE ON TEST SET\")\n",
    "        \n",
    "        self.model.eval()\n",
    "        \n",
    "        all_preds = []\n",
    "        all_targets = []\n",
    "        individual_preds = defaultdict(list)\n",
