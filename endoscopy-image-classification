    "class EnsembleTeacher(nn.Module):\n",
    "    def __init__(self, num_classes, ensemble_models = ['efficientnet', 'resnet', 'mobilenet'], pretrained=True, dropout_rate = 0.3, use_gradient_checkpointing=True):\n",
    "        super(EnsembleTeacher, self).__init__()\n",
    "        self.num_classes = num_classes\n",
    "        self.ensemble_models = ensemble_models\n",
    "        self.models = nn.ModuleDict()\n",
    "        self.use_gradient_checkpointing = use_gradient_checkpointing\n",
    "\n",
    "        for model_name in ensemble_models:\n",
    "            if model_name == 'efficientnet':\n",
    "                self.models[model_name] = self.create_efficientnet(num_classes, pretrained, dropout_rate)\n",
    "            elif model_name == 'resnet':\n",
    "                self.models[model_name] = self.create_resnet(num_classes, pretrained, dropout_rate)\n",
    "            elif model_name == 'mobilenet':\n",
    "                self.models[model_name] = self.create_mobilenet(num_classes, pretrained, dropout_rate)\n",
    "\n",
    "        print(f\"Created ensemble with {len(self.models)} models: {list(self.models.keys())}\")\n",
    "\n",
    "    def create_efficientnet(self, num_classes, pretrained, dropout_rate):\n",
    "        if pretrained:\n",
    "            model = efficientnet_b3(weights = EfficientNet_B3_Weights.IMAGENET1K_V1)\n",
    "        else:\n",
    "            model = efficientnet_b3(weights = None)\n",
    "        num_features = model.classifier[1].in_features\n",
    "        model.classifier = nn.Sequential(\n",
    "            nn.Dropout(dropout_rate),\n",
    "            nn.Linear(num_features, num_classes)\n",
    "        )\n",
    "        return model\n",
    "\n",
    "    def create_resnet(self, num_classes, pretrained, dropout_rate):\n",
    "        if pretrained:\n",
    "            model = resnet50(weights = ResNet50_Weights.IMAGENET1K_V2)\n",
    "        else:\n",
    "            model = resnet50(weights = None)\n",
    "        num_features = model.fc.in_features\n",
    "        model.fc = nn.Sequential(\n",
    "            nn.Dropout(dropout_rate),\n",
    "            nn.Linear(num_features, num_classes)\n",
    "        )\n",
    "        return model\n",
    "\n",
    "    def create_mobilenet(self, num_classes, pretrained, dropout_rate):\n",
    "        if pretrained:\n",
    "            model = mobilenet_v3_large(weights = MobileNet_V3_Large_Weights.IMAGENET1K_V2)\n",
    "        else:\n",
    "            model = mobilenet_v3_large(weights = None)\n",
    "        num_features = model.classifier[3].in_features\n",
    "        model.classifier[3] = nn.Sequential(\n",
    "            nn.Dropout(dropout_rate),\n",
    "            nn.Linear(num_features, num_classes)\n",
    "        )\n",
    "        return model\n",
    "\n",
    "    # def create_vit(self, num_classes, pretrained, dropout_rate):\n",
    "    #     if pretrained:\n",
    "    #         model = vit_b_16(weights = ViT_B_16_Weights.IMAGENET1K_V1)\n",
    "    #     else:\n",
    "    #         model = vit_b_16(weights = None)\n",
    "    #     num_features = model.classifier.in_features\n",
    "    #     model.classifier = nn.Sequential(\n",
    "    #         nn.Dropout(dropout_rate),\n",
    "    #         nn.Linear(num_features, num_classes)\n",
    "    #     )\n",
    "    #     return model\n",
    "\n",
    "    def forward(self, x, return_individual=False):\n",
    "        individual_outputs = {}\n",
    "        for model_name, model in self.models.items():\n",
    "            individual_outputs[model_name] = model(x)\n",
    "        ensemble_output = torch.stack(list(individual_outputs.values())).mean(dim=0)\n",
    "        if return_individual:\n",
    "            return ensemble_output, individual_outputs\n",
    "        else:\n",
    "            return ensemble_output"
