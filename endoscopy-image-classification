    "\n",
    "                    try:\n",
    "                        teacher_logits, _ = self.teacher(data, return_features=True)\n",
    "                    except:\n",
    "                        teacher_logits = self.teacher(data)\n",
    "                    \n",
    "                    try:\n",
    "                        student_logits, _ = self.student(data, return_features=True)\n",
    "                    except:\n",
    "                        student_logits = self.student(data)\n",
    "                    \n",
    "                    distill_loss, loss_dict = self.distillation_loss(\n",
    "                        student_logits,\n",
    "                        teacher_logits,\n",
    "                        target\n",
    "                    )\n",
    "                \n",
    "                val_loss += distill_loss.item()\n",
    "                val_distill_loss += loss_dict['distillation']\n",
    "                val_student_loss += loss_dict['student']\n",
    "                \n",
    "                _, predicted = student_logits.max(1)\n",
    "                total += target.size(0)\n",
    "                correct += predicted.eq(target).sum().item()\n",
    "                \n",
    "                pbar.set_postfix({\n",
    "                    'Val_Loss': f'{distill_loss.item():.4f}',\n",
    "                    'Val_Acc': f'{100.*correct/total:.2f}%'\n",
    "                })\n",
    "        \n",
    "        num_batches = len(self.val_loader)\n",
    "        val_loss = val_loss / num_batches\n",
    "        val_acc = 100. * correct / total\n",
    "        \n",
    "        # Store in history\n",
    "        self.history['val_loss'].append(val_loss)\n",
    "        self.history['val_acc'].append(val_acc)\n",
    "        self.history['val_distill_loss'].append(val_distill_loss / num_batches)\n",
    "        self.history['val_student_loss'].append(val_student_loss / num_batches)\n",
    "        \n",
    "        return val_loss, val_acc\n",
    "    \n",
    "    def train(self, num_epochs=2, patience=10, min_delta=0.001):               #Change Epoch Here\n",
    "\n",
    "        print(f\"\\n🎓 STARTING KNOWLEDGE DISTILLATION TRAINING\")\n",
    "        print(\"=\" * 70)\n",
    "        print(f\"Total epochs: {num_epochs}\")\n",
    "        print(f\"Early stopping patience: {patience}\")\n",
    "        print(\"=\" * 70)\n",
    "        \n",
    "        best_val_acc = 0.0\n",
    "        best_model_state = None\n",
    "        epochs_without_improvement = 0\n",
    "        \n",
    "        start_time = time.time()\n",
    "        \n",
    "        for epoch in range(num_epochs):\n",
    "            epoch_start = time.time()\n",
    "            \n",
    "            # Clear GPU memory\n",
    "            if epoch % 5 == 0:\n",
    "                gc.collect()\n",
    "                torch.cuda.empty_cache()\n",
    "\n",
    "            train_loss, train_acc = self.train_epoch(epoch)\n",
    "            val_loss, val_acc = self.validate_epoch(epoch)\n",
    "            \n",
    "            epoch_time = time.time() - epoch_start\n",
    "            \n",
    "            print(f\"\\n{'='*70}\")\n",
    "            print(f\"Epoch {epoch+1}/{num_epochs} - Time: {epoch_time:.1f}s\")\n",
    "            print(f\"{'='*70}\")\n",
    "            print(f\"Train Loss: {train_loss:.4f} | Train Acc: {train_acc:.2f}%\")\n",
    "            print(f\"Val Loss:   {val_loss:.4f} | Val Acc:   {val_acc:.2f}%\")\n",
    "            \n",
    "            if len(self.history['train_distill_loss']) > 0:\n",
    "                print(f\"\\nLoss Components:\")\n",
    "                print(f\"  Distillation: {self.history['train_distill_loss'][-1]:.4f}\")\n",
    "                print(f\"  Student CE:   {self.history['train_student_loss'][-1]:.4f}\")\n",
    "                if self.use_feature_distillation and len(self.history['train_feature_loss']) > 0:\n",
    "                    print(f\"  Feature:      {self.history['train_feature_loss'][-1]:.4f}\")\n",
    "                if self.use_attention_transfer and len(self.history['train_attention_loss']) > 0:\n",
    "                    print(f\"  Attention:    {self.history['train_attention_loss'][-1]:.4f}\")\n",
    "\n",
    "            if torch.cuda.is_available():\n",
    "                mem_allocated = torch.cuda.memory_allocated() / 1024**3\n",
    "                mem_reserved = torch.cuda.memory_reserved() / 1024**3\n",
    "                print(f\"\\nGPU Memory: {mem_allocated:.2f}GB allocated, {mem_reserved:.2f}GB reserved\")\n",
    "\n",
    "            if val_acc > best_val_acc + min_delta:\n",
    "                best_val_acc = val_acc\n",
    "                best_model_state = copy.deepcopy(self.student.state_dict())\n",
    "                epochs_without_improvement = 0\n",
    "                print(f\"\\n✅ New best validation accuracy: {best_val_acc:.2f}%\")\n",
    "                print(f\"   Model checkpoint saved\")\n",
    "            else:\n",
    "                epochs_without_improvement += 1\n",
    "                print(f\"\\n⏳ Epochs without improvement: {epochs_without_improvement}/{patience}\")\n",
    "                \n",
    "                if epochs_without_improvement >= patience:\n",
    "                    print(f\"\\n⏰ Early stopping triggered!\")\n",
    "                    print(f\"   Best validation accuracy: {best_val_acc:.2f}%\")\n",
    "                    break\n",
    "            \n",
    "        if best_model_state is not None:\n",
    "            self.student.load_state_dict(best_model_state)\n",
    "            print(f\"\\n✅ Loaded best model checkpoint (Val Acc: {best_val_acc:.2f}%)\")\n",
    "        \n",
    "        total_time = time.time() - start_time\n",
    "        print(f\"\\n🎉 TRAINING COMPLETED!\")\n",
    "        print(f\"   Total time: {total_time/60:.1f} minutes\")\n",
    "        print(f\"   Best validation accuracy: {best_val_acc:.2f}%\")\n",
    "        \n",
    "        return best_val_acc\n",
    "    \n",
    "    def plot_training_history(self):\n",
    "\n",
    "        num_plots = 3 if (self.use_feature_distillation or self.use_attention_transfer) else 2\n",
    "        fig, axes = plt.subplots(1, num_plots, figsize=(num_plots * 6, 5))\n",
    "        \n",
    "        if num_plots == 2:\n",
    "            axes = [axes[0], axes[1]]\n",
    "        \n",
