    "                'use_feature_distillation': self.use_feature_distillation,\n",
    "                'use_attention_transfer': self.use_attention_transfer\n",
    "            }\n",
    "        }, filepath)\n",
    "        \n",
    "        print(f\"\\n💾 Distilled student model saved to: {filepath}\")"
