    "class TeacherTrainer:\n",
    "    def __init__(self, model, train_loader, val_loader, num_classes, device='cuda'):\n",
    "        self.model = model.to(device)\n",
    "        self.train_loader = train_loader\n",
    "        self.val_loader = val_loader\n",
    "        self.num_classes = num_classes\n",
    "        self.device = device\n",
    "\n",
    "        self.train_history = defaultdict(list)\n",
    "        self.val_history = defaultdict(list)\n",
    "        self.individual_histories = defaultdict(lambda: defaultdict(list))\n",
    "\n",
    "        # Enable mixed precision training for memory efficiency\n",
    "        self.scaler = torch.amp.GradScaler()\n",
    "        self.use_amp = True\n",
    "\n",
    "    def setup_training(self, learning_rate = 1e-4, weight_decay = 1e-4, label_smoothing=0.1, use_mixup=True, mixup_alpha=0.2):\n",
    "        print(\"Setting up training configuration...\")\n",
    "        self.optimizer = optim.AdamW(\n",
    "            self.model.parameters(),\n",
    "            lr = learning_rate,\n",
    "            weight_decay = weight_decay,\n",
    "            betas = (0.9, 0.999)\n",
    "        )\n",
    "\n",
    "        self.scheduler = CosineAnnealingLR(\n",
    "            self.optimizer,\n",
    "            T_max = len(self.train_loader)*50,\n",
    "            eta_min = learning_rate * 0.01\n",
    "        )\n",
    "\n",
    "        self.criterion = nn.CrossEntropyLoss(label_smoothing=label_smoothing)\n",
    "\n",
    "        self.use_mixup = use_mixup\n",
    "        self.mixup_alpha = mixup_alpha\n",
    "\n",
    "        print(f\"Optimizer: AdamW (lr={learning_rate}, weight_decay={weight_decay})\")\n",
    "        print(f\"Scheduler: CosineAnnealingLR\")\n",
    "        print(f\"Loss: CrossEntropyLoss (label_smoothing={label_smoothing})\")\n",
    "        print(f\"Mixup: {'Enabled' if use_mixup else 'Disabled'}\")\n",
    "\n",
    "    def mixup_data(self, X, y, alpha=1.0):\n",
    "        if alpha > 0:\n",
    "            lam = np.random.beta(alpha, alpha)\n",
    "        else:\n",
    "            lam = 1\n",
    "\n",
    "        batch_size = X.size(0)\n",
    "        index = torch.randperm(batch_size).to(self.device)\n",
    "        mixed_x = lam*X+(1-lam)*X[index, :]\n",
    "        y_a, y_b = y, y[index]\n",
    "\n",
    "        return mixed_x, y_a, y_b, lam\n",
    "\n",
    "    def mixup_criterion(self, pred, y_a, y_b, lam):\n",
    "        return lam * self.criterion(pred, y_a) + (1-lam) * self.criterion(pred, y_b)\n",
    "\n",
    "    def train_epoch(self, epoch):\n",
    "        self.model.train()\n",
    "\n",
    "        running_loss = 0.0\n",
    "        running_ensemble_loss = 0.0\n",
    "        individual_losses = defaultdict(float)\n",
    "        correct = 0\n",
    "        total = 0\n",
    "\n",
    "        pbar = tqdm(self.train_loader, desc = f'Epoch {epoch+1} [Train]')\n",
    "\n",
    "        for batch_idx, (data, target) in enumerate(pbar):\n",
    "            \n",
    "            data, target = data.to(self.device), target.to(self.device)\n",
    "            \n",
    "            if self.use_mixup and np.random.random() > 0.5:\n",
    "                mixed_data, y_a, y_b, lam = self.mixup_data(data, target, self.mixup_alpha)\n",
    "                ensemble_output, individual_outputs = self.model(mixed_data, return_individual=True)\n",
    "                ensemble_loss = self.mixup_criterion(ensemble_output, y_a, y_b, lam)\n",
    "                individual_loss_values = {}\n",
    "\n",
    "                for model_name, outpout in individual_outputs.items():\n",
    "                    individual_loss_values[model_name] = self.mixup_criterion(outpout, y_a, y_b, lam)\n",
    "                \n",
    "                total_loss = ensemble_loss\n",
    "                for loss_val in individual_loss_values.values():\n",
    "                    total_loss += loss_val\n",
    "            else:\n",
    "                ensemble_output, individual_outputs = self.model(data, return_individual=True)\n",
    "                ensemble_loss = self.criterion(ensemble_output, target)\n",
    "                \n",
    "                individual_loss_values = {}\n",
    "                for model_name, outpout in individual_outputs.items():\n",
    "                    individual_loss_values[model_name] = self.criterion(outpout, target)\n",
    "\n",
    "                total_loss = ensemble_loss\n",
    "                for loss_val in individual_loss_values.values():\n",
    "                    total_loss += loss_val\n",
    "            \n",
    "            self.optimizer.zero_grad()\n",
    "            # total_loss.backward()\n",
    "            self.scaler.scale(total_loss).backward()\n",
    "            self.scaler.unscale_(self.optimizer)\n",
    "            torch.nn.utils.clip_grad_norm(self.model.parameters(), max_norm=1.0)\n",
    "\n",
    "            self.scaler.step(self.optimizer)\n",
    "            self.scaler.update()\n",
    "            self.scheduler.step()\n",
    "            \n",
    "            running_loss += total_loss.item()\n",
    "            running_ensemble_loss += ensemble_loss.item()\n",
    "            for model_name, loss_val in individual_loss_values.items():\n",
    "                individual_losses[model_name] += loss_val.item()\n",
    "\n",
    "            if not self.use_mixup or np.random.random() <= 0.5:\n",
    "                _, predicted = ensemble_output.max(1)\n",
    "                total += target.size(0)\n",
    "                correct += predicted.eq(target).sum().item()\n",
    "\n",
    "            pbar.set_postfix({\n",
    "                'Loss': f'{total_loss.item():.4f}',\n",
    "                'Ens_Loss': f'{ensemble_loss.item():.4f}',\n",
    "                'Acc': f'{100. *correct/total:.2f}%' if total > 0 else 'N/A'\n",
    "            })\n",
    "            \n",
    "            # Periodic memory cleanup\n",
    "            if batch_idx % 50 == 0:\n",
    "                torch.cuda.empty_cache()\n",
    "\n",
    "        epoch_loss = running_loss / len(self.train_loader)\n",
    "        epoch_ensemble_loss = running_ensemble_loss / len(self.train_loader)\n",
    "        epoch_acc = 100. *correct/total if total>0 else 0\n",
    "        \n",
    "        for model_name in individual_losses.keys():\n",
    "            individual_losses[model_name] /= len(self.train_loader)\n",
    "        \n",
    "        self.train_history['loss'].append(epoch_loss)\n",
    "        self.train_history['ensemble_loss'].append(epoch_ensemble_loss)\n",
    "        self.train_history['accuracy'].append(epoch_acc)\n",
    "\n",
    "        for model_name, loss_val in individual_losses.items():\n",
    "            self.individual_histories[model_name]['train_loss'].append(loss_val)\n",
    "\n",
    "        return epoch_loss, epoch_acc\n",
    "\n",
    "    def validate_epoch(self, epoch):\n",
    "        self.model.eval()\n",
    "        val_loss = 0.0\n",
    "        val_ensemble_loss = 0.0\n",
    "        individual_losses = defaultdict(float)\n",
    "        correct = 0\n",
    "        total = 0\n",
    "        individual_correct = defaultdict(float)\n",
    "\n",
    "        with torch.no_grad():\n",
    "            pbar = tqdm(self.val_loader, desc = f'Epoch {epoch+1} [Val]')\n",
    "            \n",
    "            for batch_idx, (data, target) in enumerate(pbar):\n",
    "                data, target = data.to(self.device), target.to(self.device)\n",
    "                ensemble_output, individual_outputs = self.model(data, return_individual=True)\n",
    "                ensemble_loss = self.criterion(ensemble_output, target)\n",
    "                val_ensemble_loss += ensemble_loss.item()\n",
    "                \n",
    "                for model_name, output in individual_outputs.items():\n",
    "                    loss_val = self.criterion(output, target)\n",
    "                    individual_losses[model_name] += loss_val.item()\n",
    "                    _, pred = output.max(1)\n",
    "                    individual_correct[model_name] += pred.eq(target).sum().item()\n",
    "                \n",
    "                total_loss = ensemble_loss\n",
    "                for loss_val in individual_losses.values():\n",
    "                    total_loss += loss_val\n",
    "                val_loss += total_loss.item()\n",
    "                \n",
    "                _, predicted = ensemble_output.max(1)\n",
    "                total += target.size(0)\n",
    "                correct += predicted.eq(target).sum().item()\n",
    "\n",
    "                pbar.set_postfix({\n",
    "                    'Val_Loss': f'{ensemble_loss.item():.4f}',\n",
    "                    'Val_Acc': f'{100.*correct/total:.2f}%'\n",
    "                })\n",
    "                \n",
    "                # Periodic memory cleanup\n",
    "                if batch_idx % 50 == 0:\n",
    "                    torch.cuda.empty_cache()\n",
    "                    \n",
    "        val_loss /= len(self.val_loader)\n",
    "        val_ensemble_loss /= len(self.val_loader)\n",
    "        val_acc = 100. * correct / total\n",
    "\n",
    "        individual_accs = {}\n",
    "        for model_name in individual_losses.keys():\n",
    "            individual_losses[model_name] /= len(self.val_loader)\n",
    "            individual_accs[model_name] = 100. * individual_correct[model_name] / total\n",
    "        \n",
    "        # Store history\n",
    "        self.val_history['loss'].append(val_loss)\n",
    "        self.val_history['ensemble_loss'].append(val_ensemble_loss)\n",
    "        self.val_history['accuracy'].append(val_acc)\n",
    "        \n",
    "        for model_name in individual_losses.keys():\n",
    "            self.individual_histories[model_name]['val_loss'].append(individual_losses[model_name])\n",
    "            self.individual_histories[model_name]['val_accuracy'].append(individual_accs[model_name])\n",
    "        \n",
    "        return val_loss, val_acc, individual_accs\n",
    "\n",
    "    def train(self, num_epochs=2, patience=10, min_delta=0.001):                    #Change Epoch Here\n",
    "        print(f\"\\n Starting ensemble teacher training for {num_epochs} epochs...\")\n",
    "        \n",
    "        best_val_acc = 0.0\n",
    "        best_model_state = None\n",
    "        epochs_without_improvement = 0\n",
    "\n",
    "        start_time = time.time()\n",
    "        for epoch in range(num_epochs):\n",
    "            epoch_start_time = time.time()\n",
    "            clear_gpu_memory()\n",
    "            train_loss, train_acc = self.train_epoch(epoch)\n",
    "            \n",
    "            val_loss, val_acc, individual_accs = self.validate_epoch(epoch)\n",
    "            \n",
    "            epoch_time = time.time() - epoch_start_time\n",
    "            \n",
    "            # Print epoch results\n",
    "            print(f\"\\nEpoch {epoch+1}/{num_epochs} ({epoch_time:.1f}s)\")\n",
    "            print(f\"Train Loss: {train_loss:.4f} | Train Acc: {train_acc:.2f}%\")\n",
    "            print(f\"Val Loss: {val_loss:.4f} | Val Acc: {val_acc:.2f}%\")\n",
    "            print(\"Individual Model Val Accuracies:\")\n",
    "            for model_name, acc in individual_accs.items():\n",
    "                print(f\"  {model_name}: {acc:.2f}%\")\n",
    "            \n",
    "            if torch.cuda.is_available():\n",
    "                memory_allocated = torch.cuda.memory_allocated() / 1024**3\n",
    "                memory_reserved = torch.cuda.memory_reserved() / 1024**3\n",
    "                print(f\"GPU Memory: {memory_allocated:.2f}GB allocated, {memory_reserved:.2f}GB reserved\")\n",
    "            \n",
    "            # Early stopping check\n",
    "            if val_acc > best_val_acc + min_delta:\n",
    "                best_val_acc = val_acc\n",
    "                best_model_state = copy.deepcopy(self.model.state_dict())\n",
    "                epochs_without_improvement = 0\n",
    "                print(f\"✅ New best validation accuracy: {best_val_acc:.2f}%\")\n",
    "            else:\n",
    "                epochs_without_improvement += 1\n",
    "                if epochs_without_improvement >= patience:\n",
    "                    print(f\"\\n⏰ Early stopping triggered after {epoch+1} epochs\")\n",
    "                    print(f\"Best validation accuracy: {best_val_acc:.2f}%\")\n",
    "                    break\n",
    "        \n",
    "        # Load best model\n",
    "        if best_model_state is not None:\n",
    "            self.model.load_state_dict(best_model_state)\n",
    "        \n",
    "        total_time = time.time() - start_time\n",
    "        print(f\"\\n Training completed in {total_time/60:.1f} minutes\")\n",
    "        print(f\"Best validation accuracy: {best_val_acc:.2f}%\")\n",
    "        \n",
    "        return best_val_acc\n",
    "\n",
    "    def plot_training_history(self):\n",
    "        fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "        \n",
    "        # Loss plot\n",
    "        axes[0, 0].plot(self.train_history['loss'], label='Train Total Loss', alpha=0.7)\n",
    "        axes[0, 0].plot(self.train_history['ensemble_loss'], label='Train Ensemble Loss', alpha=0.7)\n",
    "        axes[0, 0].plot(self.val_history['ensemble_loss'], label='Val Ensemble Loss', alpha=0.7)\n",
    "        axes[0, 0].set_title('Training/Validation Loss')\n",
    "        axes[0, 0].set_xlabel('Epoch')\n",
    "        axes[0, 0].set_ylabel('Loss')\n",
    "        axes[0, 0].legend()\n",
