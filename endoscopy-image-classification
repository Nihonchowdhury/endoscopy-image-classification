    "    if torch.cuda.is_available():\n",
    "        print(f\"   GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    \n",
    "    if distillation_config is None:\n",
    "        distillation_config = {\n",
    "            'temperature': 4.0,\n",
    "            'alpha': 0.7,\n",
    "            'beta': 0.3,\n",
    "            'use_feature_distillation': True,\n",
    "            'use_attention_transfer': True,\n",
    "            'feature_weight': 0.5,\n",
    "            'attention_weight': 0.3\n",
    "        }\n",
    "    \n",
    "    if training_config is None:\n",
    "        training_config = {\n",
    "            'learning_rate': 1e-3,\n",
    "            'weight_decay': 1e-4,\n",
    "            'num_epochs': 30,                     #Change Epoch Here\n",
    "            'patience': 8,\n",
    "            'min_delta': 0.001\n",
    "        }\n",
    "    \n",
    "    if use_progressive:\n",
    "        trainer = ProgressiveDistillationTrainer(\n",
    "            teacher_model=teacher_model,\n",
    "            student_model=student_model,\n",
    "            train_loader=train_loader,\n",
    "            val_loader=val_loader,\n",
    "            num_classes=num_classes,\n",
    "            device=device\n",
    "        )\n",
    "        trainer.setup_progressive_training(\n",
    "            initial_temperature=6.0,\n",
    "            final_temperature=2.0,\n",
    "            initial_alpha=0.9,\n",
    "            final_alpha=0.5,\n",
    "            **{k: v for k, v in distillation_config.items() \n",
    "               if k not in ['temperature', 'alpha', 'beta']}\n",
    "        )\n",
    "    else:\n",
    "        trainer = KnowledgeDistillationTrainer(\n",
    "            teacher_model=teacher_model,\n",
    "            student_model=student_model,\n",
    "            train_loader=train_loader,\n",
    "            val_loader=val_loader,\n",
    "            num_classes=num_classes,\n",
    "            device=device\n",
    "        )\n",
    "        trainer.setup_training(**distillation_config)\n",
    "\n",
    "    best_val_acc = trainer.train(\n",
    "        num_epochs=training_config['num_epochs'],\n",
    "        patience=training_config['patience'],\n",
    "        min_delta=training_config.get('min_delta', 0.001)\n",
    "    )\n",
    "\n",
    "    trainer.plot_training_history()\n",
    "    test_acc, report = trainer.evaluate_student(test_loader, class_names)\n",
    "    trainer.save_distilled_model('/kaggle/working/distilled_student_final.pth')\n",
    "    \n",
